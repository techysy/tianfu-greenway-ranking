            { stravaId: 84853614, activityId: 16239238905, time: '2:48:52', speed: 34.2, heart: 153, power: 221, date: '2025年10月24日', remark: '—', qz: false, weight: 0, heightFront: 0, heightBack: 0 },
            { stravaId: 44387344, activityId: 12544894667, time: '2:49:14', speed: 34.1, heart: 160, power: 216, date: '2024年10月1日', remark: '—', qz: false, weight: 0, heightFront: 0, heightBack: 0 },
            { stravaId: 121579383, activityId: 11560329805, time: '2:59:06', speed: 32.3, heart: 166, power: 133, date: '2024年6月3日', remark: '锦城湖起点 96.42 km', qz: false, weight: 0, heightFront: 0, heightBack: 0 },
            { stravaId: 115099652, activityId: 15303578689, time: '2:48:18', speed: 34.5, heart: 158, power: 174, date: '2025年8月8日', remark: 'tt车一带一路，目标245', qz: false, weight: 0, heightFront: 60, heightBack: '封闭' },
            { stravaId: 95801820, activityId: 10129400405, time: '3:09:39', speed: 30.5, heart: 153, power: 155, date: '2023年10月30日', remark: '—', qz: false, weight: 0, heightFront: 0, heightBack: 0 }      
        ];

        function getBestIttDataBySpeed() {
            const bestDataMap = {};
            ittData.forEach(item => {
                const existing = bestDataMap[item.stravaId];
                if (!existing || item.speed > existing.speed) {
                    bestDataMap[item.stravaId] = item;
                }
            });
            return Object.values(bestDataMap);
        }

        function compareTime(timeA, timeB) {
            const [h1, m1, s1] = timeA.split(':').map(Number);
            const [h2, m2, s2] = timeB.split(':').map(Number);
            const totalA = h1 * 3600 + m1 * 60 + s1;
            const totalB = h2 * 3600 + m2 * 60 + s2;
            return totalA - totalB;
        }

        function isFastTime(time) {
            const [h, m, s] = time.split(':').map(Number);
            const total = h * 3600 + m * 60 + s;
            const limit = 2 * 3600 + 30 * 60 + 59;
            return total <= limit;
        }

        function getRankClass(index) {
            if (index === 0) return 'gold';
            if (index === 1) return 'silver';
            if (index === 2) return 'bronze';
            return 'other';
        }

        function toggleQzFilter() {
            showQzOnly = document.getElementById('qzCheckbox').checked;
            renderCards(document.querySelector('.sort-btn.active')?.textContent?.includes('用时') ? 'time' : 
                        document.querySelector('.sort-btn.active')?.textContent?.includes('速度') ? 'speed' : 
                        document.querySelector('.sort-btn.active')?.textContent?.includes('心率') ? 'heart' : 'power');
        }

        function toggleFemaleFilter() {
            showFemaleOnly = document.getElementById('femaleCheckbox').checked;
            renderCards(document.querySelector('.sort-btn.active')?.textContent?.includes('用时') ? 'time' : 
                        document.querySelector('.sort-btn.active')?.textContent?.includes('速度') ? 'speed' : 
                        document.querySelector('.sort-btn.active')?.textContent?.includes('心率') ? 'heart' : 'power');
        }

        function togglePowerDisplay() {
            showPowerPerKg = !showPowerPerKg;
            renderCards(document.querySelector('.sort-btn.active')?.textContent?.includes('用时') ? 'time' : 
                        document.querySelector('.sort-btn.active')?.textContent?.includes('速度') ? 'speed' : 
                        document.querySelector('.sort-btn.active')?.textContent?.includes('心率') ? 'heart' : 'power');
        }

        function renderCards(sortBy = 'time') {
            const buttons = document.querySelectorAll('.sort-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            const activeBtn = Array.from(buttons).find(btn => btn.textContent === (sortBy === 'time' ? '用时' : sortBy === 'speed' ? '速度' : sortBy === 'heart' ? '心率' : '功率'));
            if (activeBtn) activeBtn.classList.add('active');

            const bestIttData = getBestIttDataBySpeed();
            const ittMap = new Map(bestIttData.map(item => [item.stravaId, item]));
            
            const mergedData = ridersData.map(rider => ({
                ...rider,
                ...ittMap.get(rider.stravaId)
            })).filter(rider => rider.activityId);
            
            let filteredData = [...mergedData];
            
            if (showQzOnly) {
                filteredData = filteredData.filter(rider => rider.qz);
            }
            
            if (showFemaleOnly) {
                filteredData = filteredData.filter(rider => rider.female === true);
            }

            const sortedData = filteredData.sort((a, b) => {
                if (sortBy === 'time') {
                    return compareTime(a.time, b.time);
                } else {
                    return b[sortBy] - a[sortBy];
                }
            });

            const container = document.getElementById('cardsContainer');
            container.innerHTML = '';

            if (sortedData.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">🚴</div>
                        <div class="empty-state-text">暂无骑友数据</div>
                        <div class="empty-state-hint">${showQzOnly ? '暂无ITT认证数据' : '数据加载中...'}</div>
                    </div>
                `;
                document.getElementById('statsCount').textContent = '暂无数据';
                return;
            }

            sortedData.forEach((rider, index) => {
                const rankClass = getRankClass(index);
                const card = document.createElement('div');
                card.className = `rider-card ${rankClass}`;

                const avatarHtml = rider.avatar 
                    ? `<a href="https://www.strava.com/athletes/${rider.stravaId}" target="_blank" title="查看Strava主页" style="position: relative; display: inline-block;"><img class="avatar" src="${rider.avatar}" alt="${rider.name}">${rider.qz ? '<span style="position: absolute; bottom: -1px; right: -1px; font-size: 12px;">⚡️</span>' : ''}</a>`
                    : `<div style="position: relative; display: inline-block;"><div class="avatar">${rider.name.charAt(0)}</div>${rider.qz ? '<span style="position: absolute; bottom: -1px; right: -1px; font-size: 12px;">⚡️</span>' : ''}</div>`;

                const heartText = rider.heart > 0 ? `${rider.heart}` : '—';
                
                let powerText, powerLabel;
                if (rider.power > 0) {
                    if (showPowerPerKg && rider.weight > 0) {
                        powerText = (rider.power / rider.weight).toFixed(2);
                        powerLabel = 'W/kg';
                    } else {
                        powerText = rider.power;
                        powerLabel = 'W';
                    }
                } else {
                    powerText = '—';
                    powerLabel = 'W';
                }
                
                const timeHtml = `<span class="time-badge ${isFastTime(rider.time) ? 'fast' : 'normal'}" style="cursor: default;">${rider.time}</span>`;
                
                const dateHtml = rider.activityId 
                    ? `<a class="date-link" href="https://www.strava.com/activities/${rider.activityId}" target="_blank" title="查看原始活动">${rider.date}</a>`
                    : `${rider.date}`;
                
                const nameHtml = rider.stravaId 
                    ? `<a href="https://www.strava.com/athletes/${rider.stravaId}" target="_blank" title="查看Strava主页" style="color: inherit; text-decoration: none;">${rider.name}</a>`
                    : rider.name;
                
                const extraInfoHtml = [];
                if (rider.heightFront && rider.heightBack) {
                    extraInfoHtml.push(`<span style="color: #666; font-size: 0.75em;">框高${rider.heightFront}-${rider.heightBack}</span>`);
                }
                if (rider.weight > 0) {
                    extraInfoHtml.push(`<span style="color: #666; font-size: 0.75em;">${rider.weight}kg</span>`);
                }
                
                card.innerHTML = `
                    <div class="rank-badge ${rankClass}">${index + 1}</div>
                    ${avatarHtml}
                    <div class="rider-info">
                        <div class="rider-name${rider.female ? ' female' : ''}">${nameHtml}</div>
                        ${extraInfoHtml.length > 0 ? `<div style="display: flex; gap: 10px; margin-top: 3px;">${extraInfoHtml.join('')}</div>` : ''}
                    </div>
                    ${timeHtml}
                    <div class="stats-inline">
                        <div class="stat-item">
                            <div class="stat-item-value speed">${rider.speed}</div>
                            <div class="stat-item-label">km/h</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-item-value heart">${heartText}</div>
                            <div class="stat-item-label">bpm</div>
                        </div>
                        <div class="stat-item" style="cursor: pointer;" onclick="togglePowerDisplay()">
                            <div class="stat-item-value power">${powerText}</div>
                            <div class="stat-item-label">${powerLabel}</div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="date-cell">${dateHtml}</div>
                        <div class="remark-cell${rider.remark && rider.remark !== '—' ? ' has-remark' : ''}" title="${rider.remark}">
                            ${rider.remark}
                            ${rider.remark && rider.remark !== '—' ? `<div class="remark-tooltip">${rider.remark}</div>` : ''}
                        </div>
                    </div>
                `;

                container.appendChild(card);
            });

            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            document.getElementById('statsCount').textContent = `截止${year}.${month}.${day} 已统计${filteredData.length}位骑友数据 · 点击头像或日期可进行跳转`   ;
        }

        function updateDate() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const updateEl = document.getElementById('update-date');
            if (updateEl) {
                updateEl.textContent = `${year}.${month}.${day} 更新`;
            }
        }

        updateDate();
        renderCards('time');
    </script>
</body>
</html>
